<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude DataStore preferences from cloud backup; use the JSON export/import instead -->
        <exclude domain="file" path="datastore/"/>
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="datastore/"/>
    </device-transfer>
</data-extraction-rules>
